# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/indo_issue_tracker
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=indo_issue_tracker

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Application
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# AI & LLM Configuration
# Choose one: OpenAI or Anthropic
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Embedding Model
EMBEDDING_PROVIDER=openai # or 'huggingface' for IndoBERT
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSION=3072

# Vector Database (if using separate vector DB)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=indo-issues

# LangChain Configuration
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=indo-issue-tracker

# Scraper Configuration
SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; IndoIssueTrackerBot/1.0)
SCRAPER_DELAY=2000 # milliseconds between requests
SCRAPER_CONCURRENT_REQUESTS=5
SCRAPER_PROXY_ENABLED=false
SCRAPER_PROXY_URL=

# News Sources
KOMPAS_ENABLED=true
DETIK_ENABLED=true
TEMPO_ENABLED=true
CNN_INDONESIA_ENABLED=true
ANTARA_ENABLED=true

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=your-encryption-key-change-this

# Rate Limiting
RATE_LIMIT_TTL=60000 # 1 minute
RATE_LIMIT_MAX=100 # requests per TTL

# Bot Configuration
BOT_NAME=IssueBot
BOT_DEFAULT_MODE=explorer
BOT_MAX_CONTEXT_MESSAGES=10
BOT_TEMPERATURE=0.7
BOT_MAX_TOKENS=1000
BOT_STREAMING_ENABLED=true

# Conversation Memory
CONVERSATION_MEMORY_TTL=3600 # 1 hour in seconds
MAX_CONVERSATIONS_PER_USER=50

# Background Jobs
SCRAPING_SCHEDULE=0 */6 * * * # Every 6 hours
EMBEDDING_BATCH_SIZE=100
CATEGORIZATION_SCHEDULE=0 */1 * * * # Every hour

# Monitoring & Logging
LOG_LEVEL=info
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Analytics
GOOGLE_ANALYTICS_ID=
POSTHOG_API_KEY=

# Feature Flags
FEATURE_WHATSAPP_BOT=false
FEATURE_TELEGRAM_BOT=false
FEATURE_VOICE_INTERFACE=false
FEATURE_EMAIL_DIGEST=false

# WhatsApp (if enabled)
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=

# Telegram (if enabled)
TELEGRAM_BOT_TOKEN=

# Email (if enabled)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@indo-issue-tracker.com

# Storage (for attachments, exports, etc.)
STORAGE_PROVIDER=local # or 's3'
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
S3_BUCKET_NAME=indo-issue-tracker

# CORS
CORS_ORIGIN=http://localhost:3000
